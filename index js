const { GoogleGenerativeAI } = require("@google/generative-ai");
const express = require('express');
const app = express();
app.use(express.json());

const genAI = new GoogleGenerativeAI(process.env.API_KEY);

app.post('/assist', async (req, res) => {
  try {
    const { task } = req.body;
    const model = genAI.getGenerativeModel({ model: "gemini-1.5-flash" });
    
    const prompt = `Act as a logical productivity assistant. Analyze this task and give a priority score (1-10) and a small execution plan: ${task}`;
    
    const result = await model.generateContent(prompt);
    const response = await result.response;
    res.send({ logic: response.text() });
  } catch (error) {
    res.status(500).send({ error: "Logic Evaluation Failed" });
  }
});

const PORT = process.env.PORT || 8080;
app.listen(PORT, () => console.log(`Server running on port ${PORT}`));
